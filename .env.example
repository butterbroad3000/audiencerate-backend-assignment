# Connection details your service should read (env vars or a config file — your choice).
# These match the provided docker-compose environment.

HTTP_PORT=8080

# One HikariCP pool per database:
DB_PROFILES_JDBC_URL=jdbc:postgresql://localhost:5432/profiles
DB_SEGMENTS_JDBC_URL=jdbc:postgresql://localhost:5432/segments
DB_ACTIVATIONS_JDBC_URL=jdbc:postgresql://localhost:5432/activations

DB_USER=audiencerate
DB_PASSWORD=audiencerate

# Reasonable starting point for pool sizing (tune as you see fit):
DB_POOL_MAX_SIZE=5
DB_POOL_MIN_IDLE=1
DB_CONNECTION_TIMEOUT_MS=5000
